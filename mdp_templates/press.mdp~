title                   = OPLS Li-PTFSI in PPC
;define                  = -DPOSRES  ; position restrain the protein
; Run parameters
integrator              = md        ; leap-frog integrator
nsteps                  = 1500    ; 2 * 150000 = 300 ps
dt                      = 0.002     ; 2 fs
; Output control
nstxout-compressed      = 500        ; save coordinates every 1 ps (500 steps)
nstvout                 = 500        ; save coordinates every 1 ps (500 steps)
nstenergy               = 500        ; save coordinates every 1 ps (500 steps)
nstlog                  = 500        ; save coordinates every 1 ps (500 steps)
; Bond parameters
continuation            = no        ; Restarting after NVT 
constraint_algorithm    = lincs     ; holonomic constraints 
constraints             = h-bonds   ; bonds involving H are constrained
; Nonbonded settings 
cutoff-scheme           = Verlet    ; Buffered neighbor searching
nstlist                 = 10        ; 10 fs, largely irrelevant with Verlet scheme
; van der waals
; see https://mailman-1.sys.kth.se/pipermail/gromacs.org_gmx-users/2011-April/060081.html
; and also original OPLS publication https://content.sakai.rutgers.edu/access/content/user/kparis/biomaps_513_references/02_B_01_JACS118_11225_OPLS.pdf
vdwtype                 = cut-off
rvdw                    = 1.1
vdw-modifier            = potential-switch
rvdw-switch             = 1.05
DispCorr                = EnerPres  ; account for cut-off vdW scheme
; Electrostatics
coulombtype             = PME       ; Particle Mesh Ewald for long-range electrostatics
rcoulomb                = 1.1       ; short-range electrostatic cutoff (in nm)
; Temperature coupling is on
tcoupl                  = V-rescale                   ; modified Berendsen thermostat
tc-grps                 = System       ; two coupling groups - more accurate
tau_t                   = 0.1      ; time constant, in ps
ref_t                   = 10  ; reference temperature, one for each group, in K
; Pressure coupling is on
pcoupl                  = Parrinello-Rahman    ; Pressure coupling on in NPT
pcoupltype              = isotropic            ; uniform scaling of box vectors
tau_p                   = 0.1                  ; time constant, in ps
ref_p                   = 1.0 
compressibility         = 4.5e-5 
refcoord_scaling        = com
; Periodic boundary conditions
pbc                     = xyz       ; 3-D PBC
; Velocity generation
gen_vel                 = no        ; Velocity generation is off 

